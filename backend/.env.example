# Copy to .env and fill in real values. Never commit .env.

NODE_ENV=development
PORT=3001

# Postgres (Prisma). Use Supabase Session pooler URI in production when applicable.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public
# Optional: direct connection for migrations (e.g. Supabase non-pooler port)
# DIRECT_URL=postgresql://...

# Public base URL of this API (no trailing slash). Used for absolute upload URLs behind a reverse proxy.
# In production set to your API domain, e.g. https://api.yourdomain.com
# API_URL=https://api.yourdomain.com

# Frontend origin(s) for CORS. Single URL:
FRONTEND_URL=http://localhost:3000
# Or multiple comma-separated origins (overrides FRONTEND_URL for CORS when set):
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Trust X-Forwarded-* from reverse proxy (Hostinger / nginx). Recommended in production.
TRUST_PROXY=true

# JWT — use a long random string (32+ chars). Required in production.
JWT_SECRET=change-me-use-openssl-rand-base64-32-in-production

# Supabase (same project as DB if using Supabase Postgres)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Admin OTP email (Gmail + App Password recommended)
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-gmail-app-password

# Optional: generic SMTP instead of Gmail (also used by MailerModule for verification emails)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM="App Name" <noreply@yourdomain.com>
# APP_NAME=YourApp

# Optional legacy / seed
# ADMIN_EMAIL=
# ADMIN_PASSWORD=

# Prisma tuning (defaults are fine for most deployments)
# PRISMA_MAX_RETRIES=2
# PRISMA_FAIL_FAST_ON_STARTUP=true
# PRISMA_LOG_QUERIES=false
