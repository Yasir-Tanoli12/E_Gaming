DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public&sslmode=require&connection_limit=5&pool_timeout=20&connect_timeout=10"
JWT_SECRET="your-jwt-secret-min-32-characters-long"
PORT=3001
PRISMA_MAX_RETRIES=2
PRISMA_RETRY_BASE_DELAY_MS=250
PRISMA_RETRY_MAX_DELAY_MS=2500
PRISMA_LOG_QUERIES=false
PRISMA_FAIL_FAST_ON_STARTUP=true

# SMTP for email verification (required for production)
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=resend
SMTP_PASS=your-resend-api-key-placeholder
MAIL_FROM="CashlySweeps <onboarding@resend.dev>"
APP_NAME=CashlySweeps

# Optional
# ADMIN_EMAIL=admin@cashlysweeps.com
# ADMIN_PASSWORD=Admin@123
# FRONTEND_URL=http://localhost:3000
